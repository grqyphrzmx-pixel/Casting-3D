        "angular": "±0.5°-1°",
        "surface_finish": "Ra 1.6-6.3"
      }
    }
  },
  
  "quality_check_rules": {
    "wall_thickness": {
      "check_uniformity": true,
      "max_thickness_ratio": 2.0,
      "recommended_ratio": 1.5
    },
    "draft_angle": {
      "check_all_surfaces": true,
      "tolerance_factor": 0.8
    },
    "fillet_radius": {
      "check_sharp_corners": true,
      "min_radius_threshold": 0.5
    },
    "hot_spot": {
      "detect_junctions": true,
      "min_risk_level": "中"
    }
  },
  
  "export_settings": {
    "default_formats": ["STEP", "STL"],
    "simulation_software": ["ProCAST", "MAGMA", "FLOW-3D"],
    "cad_software": ["Mastercam", "PowerMill", "UG/NX"],
    "include_process_info": true,
    "include_quality_report": true
  },
  
  "ui_settings": {
    "default_view": "3D",
    "show_quality_warnings": true,
    "auto_check_on_load": true,
    "highlight_issues": true,
    "color_scheme": {
      "pass": "#4CAF50",
      "warning": "#FF9800",
      "fail": "#F44336"
    }
  }
}
